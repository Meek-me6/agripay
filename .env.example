# ============================================================
# MOOLRE API CREDENTIALS — placeholders only, fill in your own
# ============================================================
# Moolre's docs show requests authenticated via headers that vary
# by endpoint: X-API-USER, X-API-KEY, X-API-PUBKEY, X-API-VASKEY.
# You said you're not sure if it's one key or several — this file
# has a slot for each so whichever it turns out to be, you just
# paste into the right line(s) and leave the rest blank.

MOOLRE_API_USER=YOUR_MOOLRE_API_USER_HERE
MOOLRE_API_KEY=YOUR_MOOLRE_API_KEY_HERE
MOOLRE_API_PUBKEY=YOUR_MOOLRE_API_PUBKEY_HERE
MOOLRE_API_VASKEY=YOUR_MOOLRE_API_VASKEY_HERE

# Base URL — confirm against current Moolre docs before going live
MOOLRE_BASE_URL=https://api.moolre.com

# IMPORTANT (security):
# This .env file is for local dev convenience only with Expo Go.
# In a real build, secret keys must NEVER ship inside the mobile
# app bundle — anyone can extract them from the APK/IPA. Real
# Moolre calls (Transfers, Payments, Account) should go through
# YOUR backend, which holds the keys server-side, and the app
# just calls your backend. See src/api/moolreClient.js for the
# toggle between "demo direct-call mode" and "backend proxy mode".
