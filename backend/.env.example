# Railway PostgreSQL — Railway auto-injects this when you add a Postgres plugin
# Format: postgresql://user:password@host.railway.internal:5432/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/agripay

# JWT secret — change this in production
JWT_SECRET=agripay_jwt_secret_change_in_prod_2024

# Moolre API credentials
MOOLRE_BASE_URL=https://api.moolre.com
MOOLRE_API_USER=your_moolre_api_user
MOOLRE_API_KEY=your_moolre_api_key
MOOLRE_API_PUBKEY=your_moolre_api_pubkey
MOOLRE_API_VASKEY=your_moolre_api_vaskey
MOOLRE_ACCOUNT_NUMBER=your_moolre_account_number

# Optional: your Railway public URL (used for Moolre webhook callback)
# BACKEND_URL=https://your-service.up.railway.app

# Server port (Railway sets this automatically)
PORT=3000
